# =============================================================================
# AYRA Agent — Environment Variables (dev & production)
# Setup: cp .env.example .env
# Prod: set same keys on your host (Vercel/Railway/PM2/VPS)
# Never commit a filled .env with real secrets to git
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (required) — platform Postgres only (not user private DB)
#
# Supabase:
#   DATABASE_URL        = Transaction pooler port 6543 + ?pgbouncer=true&sslmode=require
#   DIRECT_DATABASE_URL = Session pooler port 5432 + ?sslmode=require
#   Username: postgres.YOUR_PROJECT_REF
#
# If `prisma migrate deploy` fails with P3005, use: npx prisma db push
# -----------------------------------------------------------------------------
DATABASE_URL=
DIRECT_DATABASE_URL=

# -----------------------------------------------------------------------------
# AUTH (required)
# NEXTAUTH_SECRET — openssl rand -base64 32
# NEXTAUTH_URL    — http://localhost:3000 (dev) | https://your-domain.com (prod)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# ENCRYPTION (required in production)
# Encrypts user secrets in DB: LLM keys, Telegram, X, RPC, private Postgres URL
# Generate: openssl rand -hex 32
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=

# =============================================================================
# LLM — server-wide defaults (users override in Dashboard → Settings)
# =============================================================================
OPENROUTER_API_KEY=
LLM_API_KEY=

# Optional OpenAI-compatible base URL (default: OpenRouter)
# LLM_BASE_URL=https://openrouter.ai/api/v1

# Default chat model if user has not set one
LLM_MODEL=
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Default image model for image-generator skill
DEFAULT_IMAGE_MODEL=sourceful/riverflow-v2.5-pro

# =============================================================================
# X (Twitter) OAuth — platform app (enables "Connect with X" for all users)
# developer.x.com → OAuth 2.0 → Web App → callback = X_CALLBACK_URL
# Scopes: tweet.read, tweet.write, users.read, offline.access
# =============================================================================
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=http://localhost:3000/api/x/callback

# =============================================================================
# TELEGRAM
# =============================================================================
# Global fallback bot; users can set their own token in Settings
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dev: true  — worker polls Telegram (npm run worker)
# Prod: false — webhook when user saves bot in Settings
TELEGRAM_POLLING=true

# Prod: public URL if different from NEXTAUTH_URL
# TELEGRAM_WEBHOOK_URL=https://your-domain.com

# =============================================================================
# SOLANA RPC — server default (users override in Settings)
# =============================================================================
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_RPC_API_KEY=
# SOLANA_RPC_AUTH_STYLE=query   # query (Helius) | bearer (Alchemy/Ankr)

# =============================================================================
# AGENT RUNTIME LIMITS
# =============================================================================
AGENT_RUN_TIMEOUT_SECONDS=60
CHAT_DEEP_THINKING_TIMEOUT_SECONDS=120
MAX_TOOL_CALLS_PER_RUN=5

# =============================================================================
# WORKER — run: npm run worker (one instance only!)
# =============================================================================

# AYRA token alerts (Telegram push when filters pass)
AYRA_ALERTS_ENABLED=true
AYRA_ALERTS_INTERVAL_MINUTES=3
# Legacy aliases (still supported):
# MEME_ALERTS_ENABLED=true
# MEME_ALERTS_INTERVAL_MINUTES=3

# AYRA Brain — scheduled tweets, reminders, calendar (cron in worker)
# BRAIN_WORKER_ENABLED=true   # set false to disable brain cron

# Local SQLite path when user has no private Postgres URL
# BRAIN_STORAGE_PATH=./storage/brain

# User private Postgres (chat + brain BYOD) is set per user in Dashboard → Settings
# No env var needed — stored encrypted on User.brainDatabaseUrl

# =============================================================================
# REDIS (optional — reserved for future job queue; not required for v0.1 worker)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# RUNTIME
# =============================================================================
# NODE_ENV=production

# =============================================================================
# OPTIONAL SKILLS & INTEGRATIONS
# =============================================================================
# GITHUB_TOKEN=

# Notifications (notification-skills-extra)
# DISCORD_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=
# EMAIL_WEBHOOK_URL=
# NOTIFY_EMAIL_TO=

# DevOps monitor skills (optional default URLs)
# PM2_STATUS_URL=
# NGINX_STATUS_URL=
# DOCKER_HEALTH_URL=
