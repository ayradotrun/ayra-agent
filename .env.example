# =============================================================================
# AYRA Agent — Environment Variables (dev & production)
# Setup: cp .env.example .env
# Dev: fill values below (localhost defaults work for most optional keys)
# Prod: set same keys on your host (Vercel/Railway/PM2) — see inline notes
# Never commit a filled .env with real secrets to git
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE_URL
# PostgreSQL connection string (required)
#
# Supabase (recommended):
#   DATABASE_URL        = Transaction pooler, port 6543 + ?pgbouncer=true&sslmode=require
#   DIRECT_DATABASE_URL = Session pooler, port 5432 + ?sslmode=require
#   Username: postgres.YOUR_PROJECT_REF (not just postgres)
#
# Prod example:
#   DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# DIRECT_DATABASE_URL
# Session/direct connection for Prisma migrations (required with Supabase pooler)
# Local Postgres without pooler: can be the same as DATABASE_URL
# -----------------------------------------------------------------------------
DIRECT_DATABASE_URL=

# -----------------------------------------------------------------------------
# NEXTAUTH_SECRET (required)
# Random string for JWT sessions (min 32 chars)
# Generate: openssl rand -base64 32
# Prod: MUST differ from dev; never commit real value
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=

# -----------------------------------------------------------------------------
# NEXTAUTH_URL (required)
# Dev:  http://localhost:3000
# Prod: https://your-domain.com  (no trailing slash)
# Used by: NextAuth, OpenRouter referer, X OAuth callback base URL
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# ENCRYPTION_KEY (required in production)
# Encrypts user credentials in DB (OpenRouter, Telegram, X tokens)
# Generate: openssl rand -hex 32
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# OPENROUTER_API_KEY / LLM_API_KEY (optional server fallback)
# Users can set their own key in Dashboard → Settings → LLM Provider
# https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
LLM_API_KEY=

# Optional server-wide LLM defaults (users override in Settings)
LLM_BASE_URL=
LLM_MODEL=

OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Default OpenRouter image model for image-generator skill
# Free options: sourceful/riverflow-v2.5-pro, black-forest-labs/flux.2-klein-4b
DEFAULT_IMAGE_MODEL=sourceful/riverflow-v2.5-pro

# =============================================================================
# X (Twitter) OAuth — enables "Connect with X" in Settings for ALL users
# =============================================================================
# Platform app (one X Developer app for the whole AYRA instance).
# Each user connects THEIR X account via Settings → Connect with X.
#
# Setup (developer.x.com):
#   1. Create Project + App → User authentication → OAuth 2.0 ON
#   2. Type: Web App, Automated App or Bot (confidential client)
#   3. Callback URI must EXACTLY match X_CALLBACK_URL:
#        Dev:  http://localhost:3000/api/x/callback
#        Prod: https://your-domain.com/api/x/callback
#   4. Scopes: tweet.read, tweet.write, users.read, offline.access
# -----------------------------------------------------------------------------
X_CLIENT_ID=

X_CLIENT_SECRET=

# Optional: explicit OAuth callback (recommended if NEXTAUTH_URL differs from public URL)
X_CALLBACK_URL=http://localhost:3000/api/x/callback

# -----------------------------------------------------------------------------
# TELEGRAM
# Global fallback; users override bot token in Dashboard → Settings
# @BotFather on Telegram
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

TELEGRAM_CHAT_ID=

# Dev:  true  — polling via npm run dev / npm run worker
# Prod: false — webhook registered when user saves Telegram in Settings
TELEGRAM_POLLING=true

# Prod only (optional): public URL for Telegram webhook (defaults to NEXTAUTH_URL)
# TELEGRAM_WEBHOOK_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# SOLANA RPC
# Default for wallet & token skills; users can override in Settings
# Helius example:
#   SOLANA_RPC_URL=https://mainnet.helius-rpc.com
#   SOLANA_RPC_API_KEY=your-helius-key
# Or paste full URL with key in Dashboard → Settings → Solana
# -----------------------------------------------------------------------------
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_RPC_API_KEY=
# SOLANA_RPC_AUTH_STYLE=query   # query (Helius) | bearer (Alchemy/Ankr)

# -----------------------------------------------------------------------------
# Agent limits & worker
# -----------------------------------------------------------------------------
AGENT_RUN_TIMEOUT_SECONDS=60
MAX_TOOL_CALLS_PER_RUN=5
REDIS_URL=redis://localhost:6379

# AYRA alert — auto push when tokens pass filters (worker process)
# Legacy aliases MEME_ALERTS_* still supported
AYRA_ALERTS_ENABLED=true
AYRA_ALERTS_INTERVAL_MINUTES=3
# MEME_ALERTS_ENABLED=true
# MEME_ALERTS_INTERVAL_MINUTES=3

# Prod: set on host
# NODE_ENV=production

# -----------------------------------------------------------------------------
# Optional integrations (notification / devops skills)
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=
# DISCORD_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=
# EMAIL_WEBHOOK_URL=
# NOTIFY_EMAIL_TO=
