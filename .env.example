# =============================================================================
# AYRA Agent — Environment Variables
# Setup:
#   cp .env.example .env
#   # Edit DATABASE_URL, NEXTAUTH_SECRET, ENCRYPTION_KEY
#   npm install && npm run setup
# Docs: docs/getting-started.md · docs/slash-commands.md
# =============================================================================

# =============================================================================
# 1. DATABASE (required) — platform Postgres for AYRA only
#    NOT the user's private DB — that is set in Dashboard → Settings after login
#
#    REGION: use the same region as:
#      - the server/VPS where the app runs (e.g. eu-central-1 / Germany)
#      - the private DB URL users paste in Settings (chat/brain)
#    Platform + private in different regions = slow chat/Telegram.
#
#    Self-host VPS: platform = .../platform_db , private in Settings = .../private_db (same host)
# =============================================================================
# Supabase:
#   DATABASE_URL        = Transaction pooler URI + ?pgbouncer=true&sslmode=require
#   DIRECT_DATABASE_URL = Session pooler or direct URI + ?sslmode=require
# Solo self-host: allow same Postgres for platform + chat/brain (Settings → Private Database)
AYRA_ALLOW_PLATFORM_BRAIN_DB=true
DATABASE_URL=
DIRECT_DATABASE_URL=

# =============================================================================
# 2. AUTH (required)
# =============================================================================
# NEXTAUTH_SECRET → openssl rand -base64 32
NEXTAUTH_SECRET=
# Dev: http://localhost:3000 | Prod: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000
# Comma-separated admin emails (access /dashboard/admin)
ADMIN_EMAILS=

# =============================================================================
# 3. EMAIL — sign-up verification & password reset (SMTP)
#    Dev: leave SMTP_HOST/SMTP_FROM empty → codes print in server log as [email:dev]
#    Prod: use Resend, Gmail App Password, or any SMTP provider
# =============================================================================
# Resend example (domain must be verified at resend.com):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxx
#   SMTP_FROM=AYRA Agent <support@yourdomain.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
APP_NAME=AYRA Agent

# =============================================================================
# 4. ENCRYPTION (required in production)
#    Encrypts user API keys, Telegram, X, private Postgres URLs in platform DB
# =============================================================================
# ENCRYPTION_KEY → openssl rand -hex 32
ENCRYPTION_KEY=

# =============================================================================
# 5. LLM — server fallback (users can override in Settings)
# =============================================================================
OPENROUTER_API_KEY=
LLM_API_KEY=
# LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=
OPENROUTER_MODEL=google/gemma-4-31b-it:free
DEFAULT_IMAGE_MODEL=sourceful/riverflow-v2.5-pro

# =============================================================================
# 6. AGENT RUNTIME — agent/ module used here (TypeScript)
#    Repo-root agent/ = source → src/lib/agent/ (chat runtime)
#    No extra env for agent/ folder — use variables below
# =============================================================================
AGENT_RUN_TIMEOUT_SECONDS=60
CHAT_DEEP_THINKING_TIMEOUT_SECONDS=120
MAX_TOOL_CALLS_PER_RUN=6
CHAT_HISTORY_TURNS=8
LLM_MAX_TOKENS=1536
LLM_REQUEST_TIMEOUT_MS=45000
MAX_LLM_FALLBACK_ATTEMPTS=3

# Jina is per-user in Dashboard → Web Search (BYOK). See docs/jina-web-search.md — not read from server .env.

# =============================================================================
# 7. PYTHON RUNTIME (required) — cron/ + skills/ modules used here
#    Worker auto-starts sidecar on port 8765
# =============================================================================
AYRA_PYTHON_REQUIRED=true
AYRA_PYTHON_URL=http://127.0.0.1:8765
AYRA_PYTHON_PORT=8765
# AYRA_PYTHON_BIN=python

# Repo-root skills/ (SKILL.md playbooks) — auto-detect in dev
# AYRA_REPO_ROOT=
# AYRA_SKILLS_DIR=

# =============================================================================
# 8. WORKER — npm run worker (single instance only!)
#    Runs: Python runtime, brain cron, Telegram gateway
# =============================================================================
# BRAIN_WORKER_ENABLED=true
# BRAIN_STORAGE_PATH=./storage/brain

# Telegram → Node agent (localhost only)
AYRA_WORKER_INTERNAL_PORT=8790
AYRA_WORKER_INTERNAL_URL=http://127.0.0.1:8790
# AYRA_INTERNAL_API_SECRET=   # required in production

# =============================================================================
# 9. TELEGRAM
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Dev: polling | Prod: false + webhook
TELEGRAM_POLLING=true
# Gateway Python (default). false = legacy TypeScript polling
AYRA_TELEGRAM_PYTHON=true
# TELEGRAM_WEBHOOK_URL=https://your-domain.com

# =============================================================================
# 10. X (Twitter) OAuth — platform app
# =============================================================================
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=http://localhost:3000/api/x/callback

# =============================================================================
# 11. SOLANA RPC — server default (users override in Settings)
# =============================================================================
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_RPC_API_KEY=
# SOLANA_RPC_AUTH_STYLE=query

# Helius — wallet analyzer (/w): funding source, bundle detection, token transfers
# https://github.com/yunus-0x/walletanalyzer | https://dev.helius.xyz
HELIUS_API_KEY=
# Falls back to SOLANA_RPC_API_KEY if RPC is Helius

# =============================================================================
# 12. OPTIONAL
# =============================================================================
REDIS_URL=redis://localhost:6379
# NODE_ENV=production

# AgentMemory semantic search (https://github.com/rohitg00/agentmemory)
AGENTMEMORY_AUTO_START=false
# AGENTMEMORY_URL=http://127.0.0.1:3111
# AGENTMEMORY_SECRET=

# Skill integrations
# GITHUB_TOKEN=
# DISCORD_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=
# EMAIL_WEBHOOK_URL=
# NOTIFY_EMAIL_TO=
# PM2_STATUS_URL=
# NGINX_STATUS_URL=
# DOCKER_HEALTH_URL=
